  "description": "冷库智能监管平台 - 后端服务（Express + TypeScript）",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/middlewares/adminAuth.test.ts src/jobs/quotaDayRollover.test.ts",
    "seed:passwords": "tsx src/scripts/seedPasswords.ts",
    "mock:sensors": "tsx src/scripts/mockSensors.ts",
    "gen:forecasts": "tsx src/scripts/generateForecasts.ts"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3",
    "openai": "^4.65.0",
    "pdfmake": "^0.3.8",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.23.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  },
