{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "build": {
    "env": {
      "VITE_USE_MOCK": "1"
    }
  },
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/((?!api/|ws(?:$|/)).*)",
      "destination": "/index.html"
    }
  ]
}
