# =============================================================
# 冷库智能监管平台 - 环境变量示例
# 复制为 .env 并按需修改；切勿提交真实密钥到仓库
# =============================================================

# ---- 应用 ----
APP_ENV=development
APP_PORT=4000
APP_NAME=coldhero
# 前端访问地址（用于 CORS 白名单，多个用逗号分隔）
APP_CORS_ORIGINS=http://localhost:5173

# JWT 鉴权密钥（生产环境务必使用强随机串）
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- MySQL（主库） ----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=coldhero
MYSQL_PASSWORD=coldhero_pwd
MYSQL_DATABASE=coldhero
MYSQL_ROOT_PASSWORD=root_pwd
MYSQL_CONNECTION_LIMIT=10

# ---- Redis（缓存 / 限流 / 队列） ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- AI 大模型（DeepSeek / 通义千问，二选一，均兼容 OpenAI SDK 协议） ----
# DeepSeek 默认 BaseURL：https://api.deepseek.com
# 通义千问 OpenAI 兼容 BaseURL：https://dashscope.aliyuncs.com/compatible-mode/v1
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=replace-with-your-key
# DeepSeek 可选模型：deepseek-chat（V3，flash 等价）/ deepseek-reasoner（R1，pro 等价）
# 通义千问可选模型：qwen-plus / qwen-turbo / qwen-max
AI_MODEL_FAST=deepseek-chat
AI_MODEL_PRO=deepseek-reasoner
AI_TIMEOUT_MS=60000

# ---- 阿里云 OSS（图片 / 报告文件存储） ----
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_BUCKET=coldhero-bucket
ALI_OSS_ACCESS_KEY_ID=your-access-key-id
ALI_OSS_ACCESS_KEY_SECRET=your-access-key-secret
ALI_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# 公网访问 CDN 域名（可选）
ALI_OSS_PUBLIC_BASE_URL=https://coldhero-bucket.oss-cn-hangzhou.aliyuncs.com

# ---- 阿里云 RDS（远程同步目标库；用于 faq_topics 同步） ----
ALI_RDS_HOST=rm-xxx.mysql.rds.aliyuncs.com
ALI_RDS_PORT=3306
ALI_RDS_USER=coldhero_sync
ALI_RDS_PASSWORD=please-change-me
ALI_RDS_DATABASE=coldhero

# ---- 任务队列 / 限流 ----
RATE_LIMIT_TIMEZONE=Asia/Shanghai
QUEUE_CONCURRENCY=2

# ---- 预测模型（阶段 6） ----
# 预测结果 CSV 兑底目录（容器内路径），文件名格式 {zone_code}.csv
FORECAST_CSV_DIR=/app/storage/forecasts
# 可选：Python 预测微服务地址；为空时仅使用上述 CSV
# 微服务约定接口：POST {url}/predict { zoneCode, from, to, intervalSec }
PYTHON_FORECAST_URL=

# ---- AI 检测报告（阶段 8） ----
# PDF 中文字体路径；为空时自动按预设路径表搜索（Linux/Win 内置 / storage/fonts/*.otf）
# 推荐放置：backend/storage/fonts/NotoSansSC-Regular.otf
REPORT_FONT_PATH=

# ---- 日志 ----
LOG_LEVEL=info
